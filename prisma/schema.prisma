generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  username            String?         @unique
  email               String?         @unique
  emailVerified       DateTime?
  image               String?
  password            String
  role                String          @default("USER")
  permissions         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  phone               String?
  accounts            Account[]
  addresses           Address[]
  buyerConversations  Conversation[]  @relation("BuyerConversations")
  sellerConversations Conversation[]  @relation("SellerConversations")
  receivedMessages    DirectMessage[] @relation("ReceivedMessages")
  sentMessages        DirectMessage[] @relation("SentMessages")
  orders              Order[]
  products            Product[]       @relation("UserProducts")
  reviews             Review[]
  sessions            Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  street     String
  buildingNo String?
  zoneNo     String?
  city       String
  zip        String?
  country    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id                 String         @id @default(cuid())
  name               String
  nameAr             String?
  slug               String         @unique
  sku                String?        @unique
  brandName          String?
  description        String
  descriptionAr      String?
  price              Decimal
  salePrice          Decimal?
  stock              Int            @default(0)
  inStock            Boolean        @default(true)
  images             String
  specs              String?
  sizes              String?
  colors             String?
  materials          String?
  materialsAr        String?
  careInstructions   String?
  careInstructionsAr String?
  featured           Boolean        @default(false)
  categoryId         String?
  brandId            String?
  sellerId           String?
  status             String         @default("APPROVED")
  views              Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  position           Int            @default(0)
  conversations      Conversation[]
  orderItems         OrderItem[]
  brand              Brand?         @relation(fields: [brandId], references: [id])
  category           Category?      @relation(fields: [categoryId], references: [id])
  seller             User?          @relation("UserProducts", fields: [sellerId], references: [id])
  reviews            Review[]

  @@index([categoryId])
  @@index([brandId])
  @@index([sellerId])
  @@index([status])
}

model Category {
  id                 String     @id @default(cuid())
  name               String
  nameAr             String?
  slug               String     @unique
  description        String?
  descriptionAr      String?
  image              String?
  featured           Boolean    @default(false)
  showInHomeTabs     Boolean    @default(false)
  orderInHomeTabs    Int        @default(0)
  showInHomeCurated  Boolean    @default(false)
  orderInHomeCurated Int        @default(0)
  parentId           String?
  createdAt          DateTime   @default(now())
  parent             Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children           Category[] @relation("CategoryToCategory")
  products           Product[]
}

model Order {
  id               String      @id @default(cuid())
  userId           String?
  status           String      @default("PENDING")
  paymentMethod    String      @default("COD")
  paymentId        String?
  total            Decimal
  voucherId        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  shippingMethod   String?
  phone            String?
  assignedDriverId String?
  messages         Message[]
  assignedDriver   Driver?     @relation(fields: [assignedDriverId], references: [id])
  user             User?       @relation(fields: [userId], references: [id])
  voucher          Voucher?    @relation(fields: [voucherId], references: [id])
  items            OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([assignedDriverId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?  @unique
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Message {
  id        String   @id @default(cuid())
  orderId   String
  content   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal
  size      String?
  color     String?
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String          @id @default(cuid())
  buyerId   String
  sellerId  String
  productId String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  buyer     User            @relation("BuyerConversations", fields: [buyerId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])
  seller    User            @relation("SellerConversations", fields: [sellerId], references: [id])
  messages  DirectMessage[]

  @@unique([buyerId, sellerId, productId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Banner {
  id            String   @id @default(cuid())
  title         String
  titleAr       String?
  subtitle      String?
  subtitleAr    String?
  description   String?
  descriptionAr String?
  image         String
  mobileImage   String?
  link          String?
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id            String    @id @default(cuid())
  name          String    @unique
  nameAr        String?
  slug          String    @unique
  logo          String?
  description   String?
  descriptionAr String?
  featured      Boolean   @default(false)
  showInHome    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
}

model Voucher {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String    @default("FIXED")
  value      Decimal
  expiryDate DateTime?
  usageLimit Int       @default(0)
  usedCount  Int       @default(0)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  orders     Order[]
}

model AbandonedCheckout {
  id            String   @id @default(cuid())
  email         String?
  fullName      String?
  phone         String?
  address       String?
  country       String?
  city          String?
  buildingNo    String?
  street        String?
  zoneNo        String?
  zip           String?
  cartItems     String   // JSON array of cart items
  cartTotal     Decimal  @default(0)
  recovered     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([recovered])
}

model SiteView {
  id        String   @id @default(cuid())
  sessionId String?
  url       String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
}

model ActiveSession {
  id        String   @id @default(cuid())
  sessionId String   @unique
  lastSeen  DateTime @default(now())

  @@index([lastSeen])
}
